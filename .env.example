# Pick one Supabase target per .env.local.
# Never commit real keys.

# Local Supabase CLI
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=your-local-anon-key

# Supabase Cloud
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=your-cloud-anon-key

# Local Supabase Google OAuth provider secret.
# This is used by `supabase/config.toml` only when running local Supabase.
# Do not put the real value in .env.local or committed files.
# Export it in your shell before starting local Supabase:
# export SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_SECRET="your-google-client-secret"
